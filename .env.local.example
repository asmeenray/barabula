# Supabase (get from: Supabase Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Use ANON_KEY for older Supabase projects, PUBLISHABLE_KEY for new 2025 projects
# (check which key type your project issued in the Supabase Dashboard)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...  (use this instead if applicable)

# Server-only secrets (never prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
OPENAI_API_KEY=sk-...

# Activity + cover images — at least one key is needed for photos to appear in itineraries
# Unsplash: https://unsplash.com/developers (free tier: 50 req/hour)
UNSPLASH_ACCESS_KEY=your-unsplash-access-key
# Pexels: https://www.pexels.com/api/ (free tier: 200 req/hour) — used as fallback when Unsplash is unavailable
PEXELS_API_KEY=your-pexels-api-key
